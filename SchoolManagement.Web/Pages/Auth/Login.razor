@page "/login"
@using SchoolManagement.Web.Models.Auth
@using SchoolManagement.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Elevation="3" Class="pa-8" Style="width: 100%;">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Large" Class="mr-2" />
            School Management
        </MudText>
        
        <MudText Typo="Typo.h6" Align="Align.Center" GutterBottom="true" Class="mb-4">
            Iniciar Sesión
        </MudText>

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            
            <MudTextField @bind-Value="loginModel.Email" 
                          Label="Email" 
                          Variant="Variant.Outlined" 
                          Class="mb-4"
                          For="@(() => loginModel.Email)"
                          Disabled="@isLoading" />
            
            <MudTextField @bind-Value="loginModel.Password" 
                          Label="Contraseña" 
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password"
                          Class="mb-6"
                          For="@(() => loginModel.Password)"
                          Disabled="@isLoading" />
            
            <MudButton ButtonType="ButtonType.Submit" 
                       Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true"
                       Disabled="@isLoading">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Iniciando sesión...</span>
                }
                else
                {
                    <span>Ingresar</span>
                }
            </MudButton>
        </EditForm>

        <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4" Color="Color.Secondary">
            Sistema de Gestión Educativa v1.0
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        
        var request = new LoginRequest 
        { 
            Email = loginModel.Email, 
            Password = loginModel.Password 
        };
        
        var response = await AuthService.LoginAsync(request);
        
        if (response != null)
        {
            Snackbar.Add($"Bienvenido, {response.FullName}!", Severity.Success);
            
            // Redirigir según el rol
            Navigation.NavigateTo(GetDashboardUrl(response.Role), true);
        }
        else
        {
            Snackbar.Add("Email o contraseña incorrectos", Severity.Error);
        }
        
        isLoading = false;
    }

    private string GetDashboardUrl(int role)
    {
        return role switch
        {
            1 => "/admin",      // Admin
            2 => "/admin",      // Secretary también va a admin
            3 => "/teacher",    // Teacher
            4 => "/parent",     // Parent
            5 => "/student",    // Student
            _ => "/"
        };
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "El email es requerido")]
        [EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es requerida")]
        public string Password { get; set; } = string.Empty;
    }
}
