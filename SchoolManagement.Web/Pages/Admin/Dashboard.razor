@using Microsoft.AspNetCore.Authorization

@page "/admin"
@attribute [Authorize(Roles = "Admin,Secretary")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Panel de Administración</MudText>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                <MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h3">@totalStudents</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total de Alumnos</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                <MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h3">@totalTeachers</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total de Profesores</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                <MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.Class" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h3">@totalCourses</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total de Cursos</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                <MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h3">@totalSubjects</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total de Materias</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="2" Class="pa-4 mt-6">
        <MudText Typo="Typo.h6" Class="mb-4">Accesos Rápidos</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.School"
                           Href="/admin/students"
                           FullWidth="true">
                    Gestionar Alumnos
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.Person"
                           Href="/admin/teachers"
                           FullWidth="true">
                    Gestionar Profesores
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Class"
                           Href="/admin/courses"
                           FullWidth="true">
                    Gestionar Cursos
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    private bool loading = true;
    private int totalStudents = 0;
    private int totalTeachers = 0;
    private int totalCourses = 0;
    private int totalSubjects = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
    }

    private async Task LoadStatistics()
    {
        loading = true;
        
        try
        {
            // Obtener estadísticas llamando a las APIs
            var studentsTask = Http.GetFromJsonAsync<List<StudentDto>>("api/Students");
            var teachersTask = Http.GetFromJsonAsync<List<TeacherDto>>("api/Teachers");
            var coursesTask = Http.GetFromJsonAsync<List<CourseDto>>("api/Courses");
            var subjectsTask = Http.GetFromJsonAsync<List<SubjectDto>>("api/Subjects");

            await Task.WhenAll(studentsTask, teachersTask, coursesTask, subjectsTask);

            totalStudents = studentsTask.Result?.Count ?? 0;
            totalTeachers = teachersTask.Result?.Count ?? 0;
            totalCourses = coursesTask.Result?.Count ?? 0;
            totalSubjects = subjectsTask.Result?.Count ?? 0;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar estadísticas: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    // DTOs temporales (después crearemos archivos separados)
    public class StudentDto
    {
        public Guid Id { get; set; }
        public string FullName { get; set; } = string.Empty;
    }

    public class TeacherDto
    {
        public Guid Id { get; set; }
        public string FullName { get; set; } = string.Empty;
    }

    public class CourseDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    public class SubjectDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
