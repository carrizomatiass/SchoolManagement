@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                       Color="Color.Inherit" 
                       Edge="Edge.Start" 
                       OnClick="@(() => drawerOpen = !drawerOpen)" />
        <MudIcon Icon="@Icons.Material.Filled.School" Class="mr-2" />
        <MudText Typo="Typo.h6">School Management</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                    <MudMenuItem>@context.User.Identity?.Name</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="Logout" Icon="@Icons.Material.Filled.Logout">Cerrar Sesión</MudMenuItem>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    
    <MudDrawer @bind-Open="drawerOpen" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menú</MudText>
        </MudDrawerHeader>
        <AuthorizeView Roles="Admin,Secretary">
            <Authorized>
                <MudNavMenu>
                    <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                    <MudNavGroup Title="Estructura Académica" Icon="@Icons.Material.Filled.CalendarMonth" Expanded="false">
                        <MudNavLink Href="/admin/academic-years" Icon="@Icons.Material.Filled.CalendarToday">Años Académicos</MudNavLink>
                        <MudNavLink Href="/admin/grades" Icon="@Icons.Material.Filled.Grade">Grados</MudNavLink>
                        <MudNavLink Href="/admin/sections" Icon="@Icons.Material.Filled.Group">Secciones</MudNavLink>
                        <MudNavLink Href="/admin/subjects" Icon="@Icons.Material.Filled.MenuBook">Materias</MudNavLink>
                    </MudNavGroup>
                    <MudNavLink Href="/admin/courses" Icon="@Icons.Material.Filled.Class">Cursos</MudNavLink>
                    <MudNavLink Href="/admin/teachers" Icon="@Icons.Material.Filled.Person">Profesores</MudNavLink>
                    <MudNavLink Href="/admin/students" Icon="@Icons.Material.Filled.School">Alumnos</MudNavLink>
                </MudNavMenu>
            </Authorized>
        </AuthorizeView>
    </MudDrawer>
    
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool drawerOpen = true;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }
}
